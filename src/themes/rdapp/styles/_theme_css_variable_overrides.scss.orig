// Override or add CSS variables for your theme here

:root {

  @include media-breakpoint-up(md) {
    --ds-header-logo-height: 80px;
    --ds-header-height: 110px;
  }
  @include media-breakpoint-down(sm) {
    --ds-header-logo-height: 44px;
    --ds-header-height: 72px;
  }

  --ds-banner-text-background: rgba(0, 0, 0, 0.58);
  --ds-banner-background-gradient-width: 300px;

  --ds-header-navbar-border-bottom-height: 1px;
  --ds-header-navbar-border-bottom-color: #e5e7eb;

  /* set the next two properties as `--ds-header-navbar-border-bottom-*`
  in order to keep the bottom border of the header when navbar is expanded */

  --ds-expandable-navbar-border-top-color: #{$white};
  --ds-expandable-navbar-border-top-height: 0;
  --ds-expandable-navbar-padding-top: 0;

  --ds-item-page-img-field-default-inline-height: 24px;
  --ds-item-page-img-field-ror-inline-height: var(--ds-item-page-img-field-default-inline-height);

  --rdapp-footer-social-bg: #0f49bd;
  --rdapp-footer-social-icon-color: #ffffff;

  --rdapp-footer-main-bg: #ffffff;
  --rdapp-footer-main-border-color: #f3f4f6;
  --rdapp-footer-link-color: #28408b;
  --rdapp-footer-link-hover-color: #17357a;
  --rdapp-footer-organization-color: #6b7280;

  --rdapp-home-hero-bg: #ffffff;
  --rdapp-home-hero-title-color: #28408b;
  --rdapp-home-hero-title-light-color: #2f56be;
  --rdapp-home-hero-description-color: #6b7280;
  --rdapp-home-hero-card-bg: var(--bs-white);
  --rdapp-home-hero-card-border-color: #e9ecef;
  --rdapp-home-hero-card-shadow: 0 20px 45px -20px rgba(15, 73, 189, 0.28);
  --rdapp-home-hero-stats-shadow: 0 14px 30px -20px rgba(0, 0, 0, 0.28);
  --rdapp-home-hero-stats-icon-bg: #00a88f;
  --rdapp-home-hero-stats-label-color: #006864;
}

